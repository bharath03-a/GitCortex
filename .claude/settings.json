{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/pre-tool-use/gcx-context.sh",
            "type": "command"
          }
        ],
        "matcher": "Read"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/post-tool-use/rustfmt.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ]
  }
}
